# ============================================
# agent-management 项目 .gitignore
# Vue 3 前端 + Spring Boot 后端 + Windows 环境
# ============================================

# --- 依赖目录 ---
node_modules/
target/
!.mvn/wrapper/maven-wrapper.jar

# --- 构建产物 ---
dist/
dist-ssr/
build/
*.class
*.jar
*.war

# --- IDE & 编辑器 ---
.idea/
*.iml
*.iws
*.ipr
.vscode/
!.vscode/extensions.json
*.swp
*.swo
*~

# --- 操作系统 ---
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- 日志 ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- 环境变量 & 密钥（绝对不能提交！）---
.env
.env.local
.env.*.local
*.env
application-local.yml
application-prod.yml

# --- 其他 ---
*.local
*.ntvs*
*.njsproj
*.sln
.cache/
temp/
tmp/
